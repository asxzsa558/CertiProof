# Application
APP_NAME=VeriSure
APP_VERSION=0.1.0
DEBUG=True
API_V1_PREFIX=/api/v1
WORKER_ROLE=interactive
INTERACTIVE_SCAN_MAX_CONCURRENT=5

# Database
DATABASE_URL=postgresql+asyncpg://certiproof:certiproof@db:5432/certiproof
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
GRAPH_NAME=certiproof
GRAPH_REQUIRED=true

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOW_PUBLIC_REGISTRATION=false
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# OpenAI / LLM
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
LLM_RUNTIME_POLICY=auto
LLM_GPU_AVAILABLE=auto
VLLM_API_BASE=http://vllm:8000/v1
VLLM_MODEL=
LLAMA_CPP_API_BASE=http://llama-cpp:8080/v1
LLAMA_CPP_MODEL=
OLLAMA_REQUEST_TIMEOUT_SECONDS=300
OLLAMA_KEEP_ALIVE=30m
OLLAMA_THINK=false
DOCUMENT_EMBEDDING_MODEL=intfloat/multilingual-e5-large
DOCUMENT_EMBEDDING_DIMENSION=1024
DOCUMENT_FILE_RETRY_ATTEMPTS=3
DOCUMENT_MAX_TOTAL_PAGES=200
UPLOAD_MAX_FILE_MB=100
UPLOAD_MAX_BATCH_MB=300
ACTIVE_HISTORY_RETENTION_DAYS=90
EMBEDDING_SERVER_URL=http://localhost:8017

# MCP Gateway
MCP_GATEWAY_URL=http://localhost:9000
