# CertiProof 环境变量配置
# 复制此文件为 .env 并修改配置

# ============ 数据库配置 ============
POSTGRES_USER=certiproof
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=certiproof
# Apache AGE 属性图与 pgvector 均运行在同一 PostgreSQL 实例中。
GRAPH_NAME=certiproof
GRAPH_REQUIRED=true

# ============ 应用配置 ============
SECRET_KEY=replace-with-at-least-32-random-characters
APP_ENV=production
DEBUG=false
INTERACTIVE_SCAN_MAX_CONCURRENT=5

# ============ LLM 配置 ============
# OpenAI API Key（用于 OCR 等功能）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
DOCUMENT_EMBEDDING_MODEL=intfloat/multilingual-e5-large
DOCUMENT_EMBEDDING_DIMENSION=1024
DOCUMENT_FILE_RETRY_ATTEMPTS=3
EMBEDDING_THREADS=2
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DISABLE_XET=1

# ============ MCP 工具配置 ============
# 如需配置 MCP 工具的额外参数，在此添加
