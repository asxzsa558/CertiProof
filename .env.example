# CertiProof 环境变量配置
# 复制此文件为 .env 并修改配置

# build: 从当前源码构建；images: 从镜像仓库拉取已发布镜像。
CERTIPROOF_DEPLOY_MODE=build
CERTIPROOF_IMAGE_PREFIX=certiproof
CERTIPROOF_VERSION=latest

# ============ 数据库配置 ============
POSTGRES_USER=certiproof
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=certiproof
# Apache AGE 属性图与 pgvector 均运行在同一 PostgreSQL 实例中。
GRAPH_NAME=certiproof
GRAPH_REQUIRED=true

# ============ 应用配置 ============
SECRET_KEY=replace-with-at-least-32-random-characters
APP_ENV=production
DEBUG=false
INTERACTIVE_SCAN_MAX_CONCURRENT=5
ALLOW_PUBLIC_REGISTRATION=false
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
# 生产域名；使用 --profile production 时必须设置，Caddy 自动申请和续期 HTTPS 证书。
CERTIPROOF_DOMAIN=certiproof.example.com
CORS_ORIGINS=["https://certiproof.example.com"]

# ============ LLM 配置 ============
# OpenAI API Key（用于 OCR 等功能）
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o
# auto: CPU 使用云模型、NVIDIA GPU 使用 vLLM；local: CPU 使用 llama.cpp、GPU 使用 vLLM。
LLM_RUNTIME_POLICY=auto
LLM_GPU_AVAILABLE=auto
VLLM_API_BASE=http://vllm:8000/v1
VLLM_IMAGE=vllm/vllm-openai:v0.19.1
VLLM_MODEL=
VLLM_MAX_MODEL_LEN=16384
VLLM_GPU_MEMORY_UTILIZATION=0.9
LLAMA_CPP_API_BASE=http://llama-cpp:8080/v1
LLAMA_CPP_MODEL=
LLAMA_CPP_MODEL_FILE=qwen3-14b-q4_k_m.gguf
LLAMA_CPP_CONTEXT_SIZE=16384
LLAMA_CPP_PARALLEL=1
LLM_MODEL_DIR=./models/llm
# Ollama 本地模型由模型设置页配置；以下参数同时适用于 CPU/GPU 服务。
OLLAMA_REQUEST_TIMEOUT_SECONDS=300
OLLAMA_KEEP_ALIVE=30m
OLLAMA_THINK=false
DOCUMENT_EMBEDDING_MODEL=intfloat/multilingual-e5-large
DOCUMENT_EMBEDDING_DIMENSION=1024
DOCUMENT_FILE_RETRY_ATTEMPTS=3
EMBEDDING_THREADS=2
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DISABLE_XET=1

# ============ 容器资源保护（可按服务器调整）============
LOG_MAX_SIZE=20m
LOG_MAX_FILES=5
BACKEND_MEMORY_LIMIT=2g
WORKER_MEMORY_LIMIT=2g
POSTGRES_MEMORY_LIMIT=4g
REDIS_MEMORY_LIMIT=1g
OCR_MEMORY_LIMIT=8g
EMBEDDING_MEMORY_LIMIT=6g
TOOL_MEMORY_LIMIT=1g

# ============ MCP 工具配置 ============
# 如需配置 MCP 工具的额外参数，在此添加
