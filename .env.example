# CertiProof 环境变量配置
# 复制此文件为 .env 并修改配置

# ============ 数据库配置 ============
POSTGRES_USER=certiproof
POSTGRES_PASSWORD=certiproof
POSTGRES_DB=certiproof

# ============ 应用配置 ============
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# ============ LLM 配置 ============
# OpenAI API Key（用于 OCR 等功能）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ============ MCP 工具配置 ============
# 如需配置 MCP 工具的额外参数，在此添加
