# CertiProof NVIDIA GPU 本地模型部署
CERTIPROOF_DEPLOY_MODE=images
CERTIPROOF_IMAGE_PREFIX=ghcr.io/asxzsa558/certiproof
CERTIPROOF_VERSION=replace-with-image-version

POSTGRES_USER=certiproof
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=certiproof
SECRET_KEY=replace-with-at-least-32-random-characters
APP_ENV=production
DEBUG=false
ALLOW_PUBLIC_REGISTRATION=false

CERTIPROOF_DOMAIN=certiproof.example.com
CORS_ORIGINS=["https://certiproof.example.com"]

# vLLM 使用 GPU；OCR 与向量服务保持独立，避免和 14B 模型争抢显存。
LLM_RUNTIME_POLICY=vllm
VLLM_IMAGE=vllm/vllm-openai:v0.19.1
VLLM_API_BASE=http://vllm:8000/v1
VLLM_MODEL=Qwen/Qwen3-14B
VLLM_MAX_MODEL_LEN=16384
VLLM_GPU_MEMORY_UTILIZATION=0.9
HF_HUB_OFFLINE=0

DOCUMENT_ANALYSIS_MODE=standard
DOCUMENT_MAX_TOTAL_PAGES=200
DOCUMENT_FILE_RETRY_ATTEMPTS=3
UPLOAD_MAX_FILE_MB=100
UPLOAD_MAX_BATCH_MB=300
ACTIVE_HISTORY_RETENTION_DAYS=90
DOCUMENT_OCR_ENGINE=auto
PADDLE_DEVICE=cpu
DOCUMENT_EMBEDDING_MODEL=intfloat/multilingual-e5-large
DOCUMENT_EMBEDDING_DIMENSION=1024
EMBEDDING_THREADS=2

INTERACTIVE_SCAN_MAX_CONCURRENT=5
BACKEND_MEMORY_LIMIT=2g
WORKER_MEMORY_LIMIT=2g
POSTGRES_MEMORY_LIMIT=4g
REDIS_MEMORY_LIMIT=1g
OCR_MEMORY_LIMIT=8g
EMBEDDING_MEMORY_LIMIT=6g
TOOL_MEMORY_LIMIT=1g
LOG_MAX_SIZE=20m
LOG_MAX_FILES=5
